@model ContentBlock

@if (Model is not null && Model.SubItems.Any())
{
    if (Model.SubItems.Count.Equals(3))
    {
        if (Model.HasBackgroundColour)
        {
            <partial name="TriviaBannerThreeWithBackground" model="@Model" />
        }
        else
        {
            <partial name="TriviaBannerThreeNoBackground" model="@Model" />
        }
    }
    else if (Model.SubItems.Count.Equals(2))
    {
        if (Model.HasBackgroundColour)
        {
            <partial name="TriviaBannerTwoWithBackground" model="@Model" />
        }
        else
        {
            <partial name="TriviaBannerTwoNoBackground" model="@Model" />
        }
    }
    else if (Model.SubItems.Count > 3)
    {
        <partial name="PublicationTemplateTriviaList" model="@Model" />
    }
}