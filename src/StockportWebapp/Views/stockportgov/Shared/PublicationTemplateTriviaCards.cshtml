@model ContentBlock
@if (Model is not null && Model.SubItems.Any() is true)
{
    @if (Model.SubItems.Count.Equals(3))
    {
        string additionalCssClass = ViewData["AdditionalCssClass"] as string ?? string.Empty;

        string backgroundColourClass = Model.BackgroundColourClass.Contains("os-")
            ? Model.SolidBackgroundColourClass + " trivia-card--publication"
            : Model.BackgroundColourClass;
        

        if (Model.ColourScheme.Equals(EColourScheme.OS_Multi))
            backgroundColourClass = "trivia-card--publication-os-multi trivia-card--publication";

        string textColourClass;
         
        if (Model.TextColourClass is "text-os-purple" or "text-one-stockport-purple")
        {
            textColourClass = "text-white";
        }
        else if (Model.TextColourClass.Contains("os-"))
        {
            textColourClass = $"text{CssClassMapper.GetCssClass(EColourScheme.One_Stockport_Purple)}";
        }
        else
        {
            textColourClass = Model.TextColourClass;
        }

        string bodyTextClass = textColourClass.Equals("text-white")
            ? textColourClass
            : string.Empty;

        <section class="content-block content-block--margin @additionalCssClass" data-cy="trivia-cards">
            <ul class="navcard-wrapper navcard-wrapper--no-margin">
                @foreach (ContentBlock contentBlock in Model.SubItems)
                {
                    <partial name="TriviaCard" model="@contentBlock" view-data="@(new ViewDataDictionary(ViewData) { {"BackgroundColourClass", backgroundColourClass}, {"BorderClass", Model.BorderClass}, {"TextColourClass", textColourClass}, {"CardType", "trivia-card"}, {"NoMarginInline", "trivia-card--no-margin-inline"}, {"IsFromPublicationPage", true}, {"BodyTextClass", bodyTextClass} })" />
                }
            </ul>
        </section>
    }
    else if (Model.SubItems.Count > 3)
    {
        <partial name="PublicationTemplateTriviaList" model="@Model" />
    }
}