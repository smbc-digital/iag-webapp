@model ContentBlock

@if (Model is not null && !string.IsNullOrEmpty(Model.MailingListId))
{
    bool isDefaultColourScheme = Model.IsDefaultColourScheme;
    string backgroundColour = isDefaultColourScheme
        ? "bg-solid-teal"
        : Model.SolidBackgroundColourClass;
    
    string buttonColour = isDefaultColourScheme
        ? "btn--teal"
        : $"btn-{CssClassMapper.GetCssClass(Model.ColourScheme)}";

    string additionalCssClass = ViewData["AdditionalCssClass"] as string ?? string.Empty;

    bool isOSTheme = Model.ColourScheme.Equals(EColourScheme.OS_Lilac) || Model.ColourScheme.Equals(EColourScheme.OS_Pink) ||
        Model.ColourScheme.Equals(EColourScheme.OS_Teal) || Model.ColourScheme.Equals(EColourScheme.OS_Yellow);

    string textColour = isOSTheme
        ? $"text{CssClassMapper.GetCssClass(EColourScheme.OS_Purple)}"
        : "section__title--white";

    string buttonColourClass = isOSTheme
        ? $"btn-{CssClassMapper.GetCssClass(EColourScheme.OS_Purple)}"
        : buttonColour;

    string link = string.IsNullOrEmpty(Model.Link) ? "https://pages.comms.stockport.gov.uk/p/subscribe" : Model.Link;

    <section class="content-block content-block--margin @additionalCssClass" data-cy="subscription-banner">
        <div class="grid-container">
            <div class="subscription-banner">
                <div class="grid-100 subscription-banner__container @backgroundColour @(isOSTheme ? $"text{CssClassMapper.GetCssClass(EColourScheme.OS_Purple)}" : string.Empty)" data-cy="subscription">
                    <div class="grid-70 subscription-banner__container--right">
                        <h2 class="section__title section__title--padded-bottom h-l @textColour">@Model.Title</h2>
                            @Html.Raw(Model.BodyHtml)
                    </div>
                    
                    <div class="grid-30">
                        <a href="@link" data-cy="subscribe-button" class="btn btn--inverse btn--bold btn--full btn--chevron-forward section__content--action @buttonColourClass"><span class="btn_text">Subscribe now</span></a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}